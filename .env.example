# ── LLM provider ──────────────────────────────────────────────────────
# The agent runs OFFLINE without a key (MockLLMClient). Fill these in to
# call a real model and to compute the RAGAS metrics.
LLM_PROVIDER=openai            # openai | mistral | anthropic | google | mock
LLM_MODEL=gpt-4o-mini

# One key only, matching the provider chosen above:
OPENAI_API_KEY=
# MISTRAL_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Groq users (OpenAI-compatible endpoint). Note: Groq has no embeddings
# endpoint, so RAGAS answer_relevancy is skipped (see REPORT.md §3.2).
# OPENAI_BASE_URL=https://api.groq.com/openai/v1

# ── Langfuse observability (optional) ─────────────────────────────────
# Without these keys the agent uses a local tracer (in-memory spans).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── MCP transport (optional) ──────────────────────────────────────────
# Set to 0 to bypass the MCP subprocess and use labelled in-process calls.
AMR_USE_MCP=1
